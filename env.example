# =========================================================================
# AI Engine Configuration Settings
# =========================================================================
# Standard Options: "Google Gemini", "OpenAI", "Local Ollama", "Custom OpenAI-Compatible"
# Non-Standard Option: "Anthropic" (See specialized configuration note below)
AI_PROVIDER=Google Gemini
AI_MODEL=gemini-2.5-flash

# Universal API Secret Key 
# -> Use for Google Gemini, OpenAI, xAI Grok, DeepSeek, OpenRouter, etc.
# -> Leave completely BLANK if using Local Ollama
AI_API_KEY=

# Custom / Local Server Endpoint 
# -> Required for "Local Ollama" (Default: http://localhost:11434/v1)
# -> Required for "Custom OpenAI-Compatible" (e.g., https://api.x.ai/v1 or https://api.deepseek.com/v1)
# -> Leave completely BLANK if using native Google Gemini or native OpenAI
CUSTOM_BASE_URL=

# -------------------------------------------------------------------------
# ⚠️ SPECIAL CASE: Anthropic Claude Configuration Only
# -------------------------------------------------------------------------
# ONLY fill these two lines if you set AI_PROVIDER=Anthropic above.
# Otherwise, leave them completely blank.
ANTHROPIC_MODEL=
ANTHROPIC_API_KEY=

# =========================================================================
# JMeter Orchestration & Infrastructure Paths
# =========================================================================
# Options: "Standalone (Local)", "Distributed (Master-Worker)"
JMETER_MODE=Standalone (Local)
WORKER_IPS=

# For distributed testing: whether to cleanly terminate remote slaves when done
EXIT_WORKERS_END=True

# File System Workspace Locations
# MAC/Linux Path format: /Users/yourusername/apache-jmeter/bin/jmeter.sh
# Windows Path format: C:\apache-jmeter\bin\jmeter.bat
JMETER_PATH=/Users/vishwa/Softwares/JMeter/apache-jmeter-5.6.3/bin/jmeter
TEST_PLAN=Test_Plan.jmx
RESULT_CSV=reports/results.csv

# =========================================================================
# Performance Service Level Agreements (SLAs)
# =========================================================================
SLA_AVG_RESP=2100
SLA_ERROR_PERC=5.5
SLA_MAX_RESP=5500
